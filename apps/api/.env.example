# =============================================================================
# Strata API — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values for local development.

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------

# Async database URL (used by the application via SQLAlchemy async engine).
# Example: postgresql+asyncpg://user:pass@localhost:5432/dbname
DATABASE_URL=postgresql+asyncpg://strata:localdev@localhost:5432/strata

# Synchronous database URL (used by Alembic migrations).
# Example: postgresql+psycopg2://user:pass@localhost:5432/dbname
DATABASE_URL_SYNC=postgresql+psycopg2://strata:localdev@localhost:5432/strata

# ---------------------------------------------------------------------------
# Authentication (JWT)
# ---------------------------------------------------------------------------

# Secret key for signing JWT tokens.
# MUST be changed to a strong, unique value in production.
# In demo mode, a default is used (with a warning).
JWT_SECRET=change-me-in-production

# JWT signing algorithm (default: HS256).
# JWT_ALGORITHM=HS256

# Access token lifetime in minutes (default: 15).
# JWT_ACCESS_MINUTES=15

# Refresh token lifetime in days (default: 30).
# JWT_REFRESH_DAYS=30

# Legacy: access token lifetime in hours (default: 24).
# Not used when refresh tokens are active.
# JWT_EXPIRE_HOURS=24

# ---------------------------------------------------------------------------
# Encryption
# ---------------------------------------------------------------------------

# 32-byte encryption key for encrypting sensitive data at rest
# (e.g., connector credentials). MUST be changed in production.
ENCRYPTION_KEY=change-me-32-bytes-long-for-prod

# ---------------------------------------------------------------------------
# CORS
# ---------------------------------------------------------------------------

# Comma-separated list of allowed origins for CORS.
CORS_ORIGINS=http://localhost:3001,http://127.0.0.1:3001

# ---------------------------------------------------------------------------
# Demo Mode
# ---------------------------------------------------------------------------

# Set to "true" to enable demo mode:
# - Seeds the database with synthetic data on startup
# - Enables demo-login endpoint for persona switching
# - Relaxes JWT_SECRET check (allows default secret)
DEMO_MODE=true

# Path to demo data fixtures (auto-resolved in local dev).
# DEMO_DATA_PATH=/demo-data

# ---------------------------------------------------------------------------
# Rate Limiting
# ---------------------------------------------------------------------------

# Max login attempts per minute per IP (default: 5/minute).
# LOGIN_RATE_LIMIT=5/minute
